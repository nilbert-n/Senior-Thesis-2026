
# ===============================
# FORCE FIELD
# ===============================
bond_style harmonic
bond_coeff 1 7.5 5.9

angle_style harmonic
angle_coeff 1 5.0 150.0

pair_style hybrid/overlay lj/cut 10.0 base/rna 18.0
pair_modify shift yes
pair_coeff * * lj/cut 2.0 8.9089871814

# Base-pair interactions
pair_coeff 1 1 base/rna 0.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 1 2 base/rna 0.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 1 3 base/rna 0.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 1 4 base/rna 3.33333 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 2 2 base/rna 0.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 2 3 base/rna 5.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 2 4 base/rna 0.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 3 3 base/rna 0.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 3 4 base/rna 3.33333 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345
pair_coeff 4 4 base/rna 0.00000 3.0 13.8 1.5 0.5 1.8326 0.9425 1.8326 1.1345

special_bonds lj 0.0 0.0 1.0
Finding 1-2 1-3 1-4 neighbors ...
  special bond factors lj:    0        0        1       
  special bond factors coul:  0        0        0       
     2 = max # of 1-2 neighbors
     2 = max # of 1-3 neighbors
     4 = max # of 1-4 neighbors
     6 = max # of special neighbors
  special bonds CPU = 0.000 seconds
neighbor 15.0 bin
neigh_modify every 10 delay 0
comm_style tiled
timestep 10

# ===============================
# DUMPS
# ===============================
dump d1 all custom ${dump_stride} outputs_100/${tag}.lammpstrj id mol type q xu yu zu
dump d1 all custom 50000 outputs_100/${tag}.lammpstrj id mol type q xu yu zu
dump d1 all custom 50000 outputs_100/config_07_len50_07.dat.lammpstrj id mol type q xu yu zu
dump_modify d1 sort id

# ===============================
# THERMO
# ===============================
thermo_style custom step pe ke temp
thermo ${thermo_stride}
thermo 10000
thermo_modify flush yes

variable vpe equal pe
variable vke equal ke
variable vT  equal temp

fix fa all ave/time ${thermo_stride} 10 ${stride10} v_vpe v_vke v_vT file outputs_100/thermo_${tag}_averaged.dat
fix fa all ave/time 10000 10 ${stride10} v_vpe v_vke v_vT file outputs_100/thermo_${tag}_averaged.dat
fix fa all ave/time 10000 10 100000 v_vpe v_vke v_vT file outputs_100/thermo_${tag}_averaged.dat
fix fa all ave/time 10000 10 100000 v_vpe v_vke v_vT file outputs_100/thermo_config_07_len50_07.dat_averaged.dat

# ===============================
# EQUILIBRATION (40 ns)
# ===============================
fix fxnve all nve
variable seed0 equal 43001
fix fxl all langevin ${T_eq} ${T_eq} 100000.0 ${seed0}
fix fxl all langevin 298 ${T_eq} 100000.0 ${seed0}
fix fxl all langevin 298 298 100000.0 ${seed0}
fix fxl all langevin 298 298 100000.0 43001

run ${n_eq}
run 4000000

