# --- Output setup ------------------------------------------------
dump d1 all custom 50000 outputs/${tag}.lammpstrj id mol type q xu yu zu
dump d1 all custom 50000 outputs/7LYJ_aso_bind.lammpstrj id mol type q xu yu zu
dump_modify d1 sort id

thermo_style custom step pe ke etotal temp press density
thermo       10000
thermo_modify flush yes

variable vpe equal pe
variable vke equal ke
variable vT  equal temp
variable vE  equal etotal
variable vRg equal gyration(all)

fix favg all ave/time 10000 10 100000 v_vpe v_vke v_vT v_vE v_vRg     file outputs/thermo_${tag}_averaged.dat
fix favg all ave/time 10000 10 100000 v_vpe v_vke v_vT v_vE v_vRg     file outputs/thermo_7LYJ_aso_bind_averaged.dat

# --- NVT equilibration (50 ns) -----------------------------------
velocity all create ${T_target} 98765 rot yes dist gaussian
velocity all create 300 98765 rot yes dist gaussian

fix fxlang all langevin ${T_target} ${T_target} 1000.0 43210
fix fxlang all langevin 300 ${T_target} 1000.0 43210
fix fxlang all langevin 300 300 1000.0 43210
fix fxnve  all nve
fix recenter all momentum 1000 linear 1 1 1

run 5000000
